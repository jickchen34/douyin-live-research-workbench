 (() => {
   insert_channels_style();
   var my_username = "";
+  function __wx_parse_profile_stat_number(value) {
+    if (value === null || value === undefined) {
+      return undefined;
+    }
+    if (typeof value === "number" && Number.isFinite(value)) {
+      return Math.round(value);
+    }
+    var text = String(value).replace(/,/g, "").trim();
+    if (!text) {
+      return undefined;
+    }
+    var match = text.match(/([0-9]+(?:\.[0-9]+)?)(万|w|W|千|k|K)?/);
+    if (!match) {
+      return undefined;
+    }
+    var number = Number(match[1]);
+    if (!Number.isFinite(number)) {
+      return undefined;
+    }
+    var unit = match[2] || "";
+    if (unit === "万" || unit === "w" || unit === "W") {
+      number *= 10000;
+    } else if (unit === "千" || unit === "k" || unit === "K") {
+      number *= 1000;
+    }
+    return Math.round(number);
+  }
+  function __wx_extract_like_count_from_text(text) {
+    if (!text) {
+      return undefined;
+    }
+    var like_match = text.match(/(?:赞|点赞)\s*([0-9]+(?:\.[0-9]+)?(?:万|w|W|千|k|K)?)/);
+    if (like_match) {
+      return __wx_parse_profile_stat_number(like_match[1]);
+    }
+    return undefined;
+  }
+  function __wx_find_visible_card_like_count(feed) {
+    var title = String((feed && feed.title) || "").replace(/\s+/g, "");
+    if (!title) {
+      return {};
+    }
+    var token = title.slice(0, Math.min(18, title.length));
+    if (!token) {
+      return {};
+    }
+    var nodes = Array.from(document.querySelectorAll("article, li, [class*='card'], [class*='feed'], [class*='item'], div"));
+    var best = null;
+    for (var i = 0; i < nodes.length; i += 1) {
+      var text = (nodes[i].innerText || "").trim();
+      if (!text || text.length > 2000) {
+        continue;
+      }
+      var compact = text.replace(/\s+/g, "");
+      if (compact.indexOf(token) === -1) {
+        continue;
+      }
+      var like_count = __wx_extract_like_count_from_text(text);
+      if (like_count !== undefined) {
+        return {
+          like_count,
+          raw_like_text: text.slice(0, 240),
+        };
+      }
+      if (!best || text.length < best.length) {
+        best = text;
+      }
+    }
+    return {};
+  }
+  function __wx_enrich_feed_stats_from_card(feed) {
+    if (!feed || feed.like_count !== undefined) {
+      return feed;
+    }
+    var stats = __wx_find_visible_card_like_count(feed);
+    if (stats.like_count === undefined) {
+      return feed;
+    }
+    return {
+      ...feed,
+      ...stats,
+    };
+  }
   function __wx_insert_batch_download_btn() {
