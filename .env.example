# Do not put real secrets in this file.
VOLCENGINE_API_KEY=your_api_key_here
# 豆包 2.0 Pro 或旧 AI 分析使用的火山方舟接入点。
VOLCENGINE_ENDPOINT_ID=ep_xxx
# DeepSeek 4.0 Pro 当前使用内置接入点 ep-20260609144848-8qmcw。
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_ASR_API_KEY=your_asr_api_key_here
DOUBAO_ASR_AUTH_MODE=api_key
DOUBAO_ASR_API_MODE=standard
DOUBAO_ASR_UPLOAD_PROVIDER=mp3tourl
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.auc
DOUBAO_ASR_SUBMIT_ENDPOINT=https://openspeech.bytedance.com/api/v3/auc/bigmodel/submit
DOUBAO_ASR_QUERY_ENDPOINT=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query

# Optional: standard ASR audio URL/upload settings.
DOUBAO_ASR_PUBLIC_BASE_URL=
DOUBAO_ASR_AUDIO_URL_TEMPLATE=
DOUBAO_ASR_AUDIO_URL=

# Optional: legacy ASR auth mode.
DOUBAO_ASR_APP_KEY=
DOUBAO_ASR_ACCESS_KEY=
# Optional: batch task concurrency. Keep conservative to avoid ASR/API throttling.
BATCH_TRANSCRIBE_CONCURRENCY=2
BATCH_ANALYZE_CONCURRENCY=2

# Optional: WeChat Channels local helper executable.
WECHAT_CHANNELS_API_BASE_URL=http://127.0.0.1:38129
WECHAT_CHANNELS_BINARY_PATH=

# 可选：抖音采集代理。可以使用统一代理，也可以分别配置 HTTP/HTTPS。
DOUYIN_PROXY=
DOUYIN_HTTP_PROXY=
DOUYIN_HTTPS_PROXY=
